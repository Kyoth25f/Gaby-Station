reagent-name-umbroxol = umbroxol
reagent-desc-umbroxol = Um químico ominoso. Usado para tratar danos sagrados em quem é fraco ao véu. Overdoses podem deixar o paciente com uma sensação de frio.

reagent-name-unholy-water = água profana
reagent-desc-unholy-water = Água tratada com sangue e enxofre. Só de olhar já arrepia os ossos.

